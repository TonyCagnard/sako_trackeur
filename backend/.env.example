# Sako Trackeur — backend (modèle de configuration)
# Copier ce fichier en .env puis renseigner les valeurs.

# Générer une clé en production :
#   python -c "from django.core.management import utils; print(utils.get_random_secret_key())"
SECRET_KEY=change-me
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1

# Vide -> SQLite. Renseigner pour PostgreSQL :
#   DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DB_NAME
DATABASE_URL=

CORS_ALLOWED_ORIGINS=http://localhost:5173
